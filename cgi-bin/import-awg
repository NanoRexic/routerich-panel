#!/bin/sh

json_err() {
	printf '%s\n' "{\"ok\":false,\"error\":\"$1\"}"
	exit 0
}

json_ok() {
	iface="$1"
	printf '%s\n' "{\"ok\":true,\"message\":\"Configuration applied\",\"data\":{\"interface\":\"$iface\"}}"
	exit 0
}

json_header() {
	echo "Content-Type: application/json"
	echo ""
}

get_query_param() {
	param="$1"
	value=""
	if [ -n "$QUERY_STRING" ]; then
		case "$QUERY_STRING" in
			*${param}=*)
				value="${QUERY_STRING#*${param}=}"
				value="${value%%&*}"
				;;
		esac
	fi
	printf '%s' "$value"
}

list_amneziawg_ifaces() {
	uci show network 2>/dev/null | sed -n "s/^network\.\([^=]*\)\.proto='amneziawg'$/\1/p" | sort -u
}

iface_is_amneziawg() {
	iface="$1"
	[ -n "$iface" ] || return 1
	echo "$iface" | grep -qE '^[A-Za-z0-9_]+$' || return 1
	[ "$(uci -q get "network.${iface}.proto" 2>/dev/null)" = "amneziawg" ]
}

find_peer_for_iface() {
	iface="$1"
	peer="@amneziawg_${iface}[0]"
	if uci -q get "network.${peer}" >/dev/null 2>&1; then
		printf '%s' "$peer"
		return 0
	fi
	match=$(uci show network 2>/dev/null | grep "interface='${iface}'" | head -1 | sed -n 's/^network\.\([^=]*\)\.interface=.*/\1/p')
	if [ -n "$match" ]; then
		printf '%s' "$match"
		return 0
	fi
	return 1
}

iface_is_up() {
	iface="$1"
	if command -v ifstatus >/dev/null 2>&1; then
		ifstatus "$iface" 2>/dev/null | grep -q '"up": true'
		return $?
	fi
	ip link show "$iface" 2>/dev/null | grep -qE 'UP|LOWER_UP'
}

pick_default_iface() {
	default=""
	for iface in awg10 AWG; do
		iface_is_amneziawg "$iface" || continue
		default="$iface"
		break
	done
	if [ -n "$default" ]; then
		printf '%s' "$default"
		return 0
	fi
	for iface in $(list_amneziawg_ifaces); do
		iface_is_up "$iface" || continue
		printf '%s' "$iface"
		return 0
	done
	list_amneziawg_ifaces | head -1
}

api_list_interfaces() {
	json_header
	first=1
	default=$(pick_default_iface)
	printf '%s' '{"ok":true,"interfaces":['
	for iface in $(list_amneziawg_ifaces); do
		find_peer_for_iface "$iface" >/dev/null 2>&1 || continue
		up=0
		iface_is_up "$iface" && up=1
		[ "$first" -eq 0 ] && printf ','
		first=0
		printf '{"name":"%s","up":%s}' "$iface" "$up"
	done
	if [ "$first" -eq 1 ]; then
		printf '],"default":null}'
		exit 0
	fi
	if [ -n "$default" ]; then
		printf '],"default":"%s"}' "$default"
	else
		printf '],"default":null}'
	fi
	exit 0
}

resolve_import_target() {
	iface=$(get_query_param iface)
	if [ -z "$iface" ]; then
		iface=$(pick_default_iface)
	fi
	if ! iface_is_amneziawg "$iface"; then
		json_err "–Ш–љ—В–µ—А—Д–µ–є—Б AmneziaWG –љ–µ –љ–∞–є–і–µ–љ: ${iface:-–љ–µ —Г–Ї–∞–Ј–∞–љ}"
	fi
	PEER_SECTION=$(find_peer_for_iface "$iface")
	if [ -z "$PEER_SECTION" ]; then
		json_err "–Э–µ –љ–∞–є–і–µ–љ–∞ peer-—Б–µ–Ї—Ж–Є—П –і–ї—П –Є–љ—В–µ—А—Д–µ–є—Б–∞ $iface"
	fi
	IFACE="$iface"
}

MAX_NETWORK_BACKUPS=4
BACKUP_PREFIX='/etc/config/network.bak.'

validate_b64_key() {
	key="$1"
	name="$2"
	if [ -z "$key" ]; then
		json_err "$name –љ–µ —Г–Ї–∞–Ј–∞–љ"
	fi
	if ! echo "$key" | grep -qE '^[A-Za-z0-9+/]{43}=$'; then
		json_err "$name –љ–µ–Ї–Њ—А—А–µ–Ї—В–µ–љ (–Њ–ґ–Є–і–∞–µ—В—Б—П Base64, 44 —Б–Є–Љ–≤–Њ–ї–∞)"
	fi
}

backup_network_config() {
	count=0
	for f in "$BACKUP_PREFIX"*; do
		[ -f "$f" ] || continue
		count=$((count + 1))
	done

	while [ "$count" -ge "$MAX_NETWORK_BACKUPS" ]; do
		oldest=$(ls -1 "$BACKUP_PREFIX"* 2>/dev/null | head -n 1)
		[ -n "$oldest" ] && [ -f "$oldest" ] || break
		rm -f "$oldest"
		count=$((count - 1))
	done

	cp /etc/config/network "${BACKUP_PREFIX}$(date +%s)" 2>/dev/null
}

case "$REQUEST_METHOD" in
	GET)
		if [ "$(get_query_param action)" = "list" ]; then
			api_list_interfaces
		fi
		json_header
		json_err "Method not allowed"
		;;
	POST)
		json_header
		;;
	*)
		json_header
		json_err "Method not allowed"
		;;
esac

if [ -z "$CONTENT_LENGTH" ] || [ "$CONTENT_LENGTH" -eq 0 ]; then
	json_err "–Я—Г—Б—В–Њ–µ —В–µ–ї–Њ –Ј–∞–њ—А–Њ—Б–∞"
fi

resolve_import_target

TMPDIR="/tmp/routerich-panel"
mkdir -p "$TMPDIR"
CONF_FILE="$TMPDIR/import-$$.conf"
dd bs=1 count="$CONTENT_LENGTH" of="$CONF_FILE" 2>/dev/null

if [ ! -s "$CONF_FILE" ]; then
	rm -f "$CONF_FILE"
	json_err "–Я—Г—Б—В–Њ–є –Ї–Њ–љ—Д–Є–≥"
fi

PARSED="$TMPDIR/parsed-$$.env"
awk '
BEGIN { section = "" }
/^\[Interface\]/ { section = "interface"; next }
/^\[Peer\]/ { section = "peer"; next }
/^[[:space:]]*#/ { next }
/^[[:space:]]*$/ { next }
{
	pos = index($0, "=")
	if (pos < 1) next
	key = substr($0, 1, pos - 1)
	val = substr($0, pos + 1)
	gsub(/^[ \t]+|[ \t]+$/, "", key)
	gsub(/^[ \t]+|[ \t]+$/, "", val)
	sub(/#.*$/, "", val)
	gsub(/^[ \t]+|[ \t]+$/, "", val)
	if (length(val) < 1) next
	lkey = tolower(key)
	gsub(/ /, "", lkey)
	print section "_" lkey "=" val
}
' "$CONF_FILE" > "$PARSED"

rm -f "$CONF_FILE"

get_val() {
	grep "^${1}=" "$PARSED" 2>/dev/null | head -1 | cut -d= -f2-
}

PRIVATE_KEY=$(get_val "interface_privatekey")
PUBLIC_KEY=$(get_val "peer_publickey")
ENDPOINT=$(get_val "peer_endpoint")

validate_b64_key "$PRIVATE_KEY" "PrivateKey"

if [ -z "$PUBLIC_KEY" ]; then
	rm -f "$PARSED"
	json_err "PublicKey –љ–µ —Г–Ї–∞–Ј–∞–љ"
fi
validate_b64_key "$PUBLIC_KEY" "PublicKey"

if [ -z "$ENDPOINT" ]; then
	rm -f "$PARSED"
	json_err "Endpoint –љ–µ —Г–Ї–∞–Ј–∞–љ"
fi

# Parse endpoint host:port (supports [ipv6]:port)
case "$ENDPOINT" in
	\[*\]*:*)
		ENDPOINT_HOST=$(echo "$ENDPOINT" | sed 's/^\[\([^]]*\)\]:.*/\1/')
		ENDPOINT_PORT=$(echo "$ENDPOINT" | sed 's/^\[[^]]*\]:\([0-9]*\).*/\1/')
		;;
	*:*)
		ENDPOINT_PORT="${ENDPOINT##*:}"
		ENDPOINT_HOST="${ENDPOINT%:*}"
		;;
	*)
		rm -f "$PARSED"
		json_err "Endpoint –љ–µ–Ї–Њ—А—А–µ–Ї—В–µ–љ (–Њ–ґ–Є–і–∞–µ—В—Б—П host:port)"
		;;
esac

if [ -z "$ENDPOINT_HOST" ] || [ -z "$ENDPOINT_PORT" ]; then
	rm -f "$PARSED"
	json_err "Endpoint –љ–µ–Ї–Њ—А—А–µ–Ї—В–µ–љ (–Њ–ґ–Є–і–∞–µ—В—Б—П host:port)"
fi

# Backup (—Е—А–∞–љ–Є–Љ –љ–µ –±–Њ–ї–µ–µ MAX_NETWORK_BACKUPS –Ї–Њ–њ–Є–є)
backup_network_config

# Interface: private_key
uci -q set "network.${IFACE}.private_key=$PRIVATE_KEY"

# Clear and set list options
for opt in addresses dns; do
	uci -q delete "network.${IFACE}.${opt}" 2>/dev/null
	while uci -q delete "network.${IFACE}.${opt}" 2>/dev/null; do :; done
done

ADDR=$(get_val "interface_address")
if [ -n "$ADDR" ]; then
	IFS=',' 
	for a in $ADDR; do
		a=$(echo "$a" | sed 's/^[ \t]*//;s/[ \t]*$//')
		[ -n "$a" ] && uci add_list "network.${IFACE}.addresses=$a"
	done
	unset IFS
fi

DNS=$(get_val "interface_dns")
if [ -n "$DNS" ]; then
	IFS=','
	for d in $DNS; do
		d=$(echo "$d" | sed 's/^[ \t]*//;s/[ \t]*$//')
		[ -n "$d" ] && uci add_list "network.${IFACE}.dns=$d"
	done
	unset IFS
fi

LISTEN_PORT=$(get_val "interface_listenport")
if [ -n "$LISTEN_PORT" ]; then
	uci -q set "network.${IFACE}.listen_port=$LISTEN_PORT"
else
	uci -q delete "network.${IFACE}.listen_port" 2>/dev/null
fi

MTU=$(get_val "interface_mtu")
if [ -n "$MTU" ]; then
	uci -q set "network.${IFACE}.mtu=$MTU"
fi

# AWG obfuscation params
for pair in \
	"interface_jc:awg_jc" \
	"interface_jmin:awg_jmin" \
	"interface_jmax:awg_jmax" \
	"interface_s1:awg_s1" \
	"interface_s2:awg_s2" \
	"interface_s3:awg_s3" \
	"interface_s4:awg_s4" \
	"interface_h1:awg_h1" \
	"interface_h2:awg_h2" \
	"interface_h3:awg_h3" \
	"interface_h4:awg_h4" \
	"interface_i1:awg_i1" \
	"interface_i2:awg_i2" \
	"interface_i3:awg_i3" \
	"interface_i4:awg_i4" \
	"interface_i5:awg_i5"
do
	src="${pair%%:*}"
	dst="${pair##*:}"
	val=$(get_val "$src")
	if [ -n "$val" ]; then
		uci -q set "network.${IFACE}.${dst}=$val"
	fi
done

# Peer section
uci -q set "network.${PEER_SECTION}.public_key=$PUBLIC_KEY"
uci -q set "network.${PEER_SECTION}.endpoint_host=$ENDPOINT_HOST"
uci -q set "network.${PEER_SECTION}.endpoint_port=$ENDPOINT_PORT"

PSK=$(get_val "peer_presharedkey")
if [ -n "$PSK" ]; then
	uci -q set "network.${PEER_SECTION}.preshared_key=$PSK"
else
	uci -q delete "network.${PEER_SECTION}.preshared_key" 2>/dev/null
fi

KEEPALIVE=$(get_val "peer_persistentkeepalive")
if [ -n "$KEEPALIVE" ]; then
	uci -q set "network.${PEER_SECTION}.persistent_keepalive=$KEEPALIVE"
else
	uci -q set "network.${PEER_SECTION}.persistent_keepalive=25"
fi

# Clear and set allowed_ips
while uci -q delete "network.${PEER_SECTION}.allowed_ips" 2>/dev/null; do :; done
ALLOWED=$(get_val "peer_allowedips")
if [ -n "$ALLOWED" ]; then
	IFS=','
	for ip in $ALLOWED; do
		ip=$(echo "$ip" | sed 's/^[ \t]*//;s/[ \t]*$//')
		[ -n "$ip" ] && uci add_list "network.${PEER_SECTION}.allowed_ips=$ip"
	done
	unset IFS
else
	uci add_list "network.${PEER_SECTION}.allowed_ips=0.0.0.0/0"
	uci add_list "network.${PEER_SECTION}.allowed_ips=::/0"
fi

# Preserve route_allowed_ips=0 and description
uci -q set "network.${PEER_SECTION}.route_allowed_ips=0"

rm -f "$PARSED"

if ! uci commit network; then
	json_err "–Э–µ —Г–і–∞–ї–Њ—Б—М —Б–Њ—Е—А–∞–љ–Є—В—М –Ї–Њ–љ—Д–Є–≥—Г—А–∞—Ж–Є—О"
fi

ifdown "$IFACE" 2>/dev/null
sleep 1
if ! ifup "$IFACE" 2>/dev/null; then
	json_err "–Ъ–Њ–љ—Д–Є–≥ —Б–Њ—Е—А–∞–љ—С–љ, –љ–Њ –љ–µ —Г–і–∞–ї–Њ—Б—М –њ–Њ–і–љ—П—В—М –Є–љ—В–µ—А—Д–µ–є—Б $IFACE"
fi

json_ok "$IFACE"