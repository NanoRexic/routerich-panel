#!/bin/sh

# Релизная секция Zeroblock для смешанного прокси
ZB_SECTION="awg10"
ZB_DEFAULT_MIXED_PORT="2080"
OPERA_HTTP_PROXY="http://127.0.0.1:18080"

json_err() {
	printf '%s\n' "{\"ok\":false,\"error\":\"$1\"}"
	exit 0
}

json_ok_apply() {
	lan_ip="$1"
	socks_url="$2"
	mixed_was="$3"
	opera_was="$4"
	pkg_ver="$5"
	custom_fix="$6"
	printf '%s\n' "{\"ok\":true,\"message\":\"$7\",\"data\":{\"lan_ip\":\"$lan_ip\",\"socks_proxy\":\"$socks_url\",\"mixed_proxy_was_enabled\":$mixed_was,\"opera_section_was_enabled\":$opera_was,\"opera_proxy_version\":\"$pkg_ver\",\"needs_fix\":false,\"custom_fix_applied\":$custom_fix,\"proxy_ok\":true,\"http_proxy\":\"$OPERA_HTTP_PROXY\",\"podkop_detected\":false,\"zeroblock_available\":true}}"
	exit 0
}

json_ok_status() {
	needs_fix="$1"
	lan_ip="$2"
	socks_url="$3"
	mixed_ok="$4"
	opera_ok="$5"
	init_ok="$6"
	running_ok="$7"
	proxy_ok="$8"
	pkg_ver="$9"
	printf '%s\n' "{\"ok\":true,\"data\":{\"needs_fix\":$needs_fix,\"lan_ip\":\"$lan_ip\",\"socks_proxy\":\"$socks_url\",\"mixed_proxy_ok\":$mixed_ok,\"opera_section_ok\":$opera_ok,\"custom_init_ok\":$init_ok,\"opera_proxy_running\":$running_ok,\"proxy_ok\":$proxy_ok,\"opera_proxy_version\":\"$pkg_ver\",\"http_proxy\":\"$OPERA_HTTP_PROXY\",\"proxy_config\":{\"type\":\"http\",\"server\":\"127.0.0.1\",\"server_port\":18080},\"podkop_detected\":false,\"zeroblock_available\":true}}"
	exit 0
}

json_ok_status_podkop() {
	proxy_ok="$1"
	running_ok="$2"
	pkg_ver="$3"
	podkop_ver="$4"
	printf '%s\n' "{\"ok\":true,\"data\":{\"needs_fix\":false,\"proxy_ok\":$proxy_ok,\"opera_proxy_running\":$running_ok,\"opera_proxy_version\":\"$pkg_ver\",\"podkop_version\":\"$podkop_ver\",\"http_proxy\":\"$OPERA_HTTP_PROXY\",\"proxy_config\":{\"type\":\"http\",\"server\":\"127.0.0.1\",\"server_port\":18080},\"podkop_detected\":true,\"zeroblock_available\":false,\"blocked_reason\":\"Установлен Podkop — настройка через Zeroblock не поддерживается\"}}"
	exit 0
}

podkop_installed() {
	[ -f /etc/config/podkop ] && return 0
	[ -f /etc/init.d/podkop ] && return 0
	if opkg list-installed 2>/dev/null | grep -qE '^podkop |^luci-app-podkop '; then
		return 0
	fi
	if command -v apk >/dev/null 2>&1; then
		apk info -e podkop >/dev/null 2>&1 && return 0
		apk info -e luci-app-podkop >/dev/null 2>&1 && return 0
	fi
	return 1
}

get_podkop_version() {
	if opkg list-installed 2>/dev/null | grep -q '^podkop '; then
		opkg list-installed 2>/dev/null | awk '/^podkop / {print $3; exit}'
		return 0
	fi
	if command -v apk >/dev/null 2>&1 && apk info -e podkop >/dev/null 2>&1; then
		apk info -v podkop 2>/dev/null | head -n1 | sed 's/^podkop-//;s/-r[0-9]*$//'
		return 0
	fi
	printf ''
}

get_lan_ip() {
	ip -4 addr show br-lan 2>/dev/null | awk '/inet / {print $2; exit}' | cut -d/ -f1
}

get_opera_proxy_version() {
	opkg list-installed 2>/dev/null | awk '/^opera-proxy / {print $3; exit}'
}

upgrade_opera_proxy_package() {
	if ! command -v opkg >/dev/null 2>&1; then
		json_err "opkg не найден на роутере"
	fi

	if ! opkg update >/dev/null 2>&1; then
		json_err "Не удалось обновить список пакетов (opkg update)"
	fi

	if opkg list-installed 2>/dev/null | grep -q '^opera-proxy '; then
		if ! opkg upgrade opera-proxy >/dev/null 2>&1; then
			json_err "Не удалось обновить пакет opera-proxy (opkg upgrade)"
		fi
	else
		if ! opkg install opera-proxy >/dev/null 2>&1; then
			json_err "Не удалось установить пакет opera-proxy (opkg install)"
		fi
	fi

	[ -x /usr/bin/opera-proxy ] || json_err "opera-proxy не найден после обновления пакета"
}

get_mixed_port() {
	port=$(uci -q get "zeroblock.${ZB_SECTION}.mixed_port")
	[ -n "$port" ] || port="$ZB_DEFAULT_MIXED_PORT"
	printf '%s' "$port"
}

port_listening() {
	port="$1"
	netstat -tln 2>/dev/null | grep -qE ":${port}[[:space:]]"
}

wait_for_port() {
	port="$1"
	max_tries="$2"
	tries=0
	while [ "$tries" -lt "$max_tries" ]; do
		if port_listening "$port"; then
			return 0
		fi
		tries=$((tries + 1))
		sleep 2
	done
	return 1
}

custom_init_ok() {
	lan_ip="$1"
	mixed_port="$2"
	[ -f /etc/init.d/opera-proxy ] || return 1
	grep -q 'routerich-panel: opera-proxy fixed' /etc/init.d/opera-proxy 2>/dev/null \
		&& grep -qF -- "-proxy socks5://${lan_ip}:${mixed_port}" /etc/init.d/opera-proxy 2>/dev/null
}

opera_proxy_running() {
	/etc/init.d/opera-proxy status >/dev/null 2>&1 && port_listening 18080
}

test_http_proxy() {
	port_listening 18080 || return 1
	http_code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 15 \
		-x "$OPERA_HTTP_PROXY" http://ya.ru/ 2>/dev/null)
	case "$http_code" in
		200|301|302|307|308) return 0 ;;
	esac
	case "$http_code" in
		[0-9][0-9][0-9])
			[ "$http_code" != "000" ] && return 0
			;;
	esac
	return 1
}

wait_for_http_proxy() {
	i=0
	while [ "$i" -lt 12 ]; do
		if test_http_proxy; then
			return 0
		fi
		i=$((i + 1))
		sleep 2
	done
	return 1
}

collect_status_podkop() {
	pkg_ver=$(get_opera_proxy_version)
	podkop_ver=$(get_podkop_version)
	running_ok=0
	proxy_ok=0

	if opera_proxy_running; then running_ok=1; fi
	if test_http_proxy; then proxy_ok=1; fi

	json_ok_status_podkop "$proxy_ok" "$running_ok" "$pkg_ver" "$podkop_ver"
}

collect_status() {
	lan_ip=$(get_lan_ip)
	[ -n "$lan_ip" ] || lan_ip=$(uci -q get network.lan.ipaddr)
	mixed_port=$(get_mixed_port)
	pkg_ver=$(get_opera_proxy_version)

	mixed_ok=0
	opera_ok=0
	init_ok=0
	running_ok=0
	proxy_ok=0

	[ "$(uci -q get "zeroblock.${ZB_SECTION}.enable_mixed_proxy")" = "1" ] && mixed_ok=1
	[ "$(uci -q get zeroblock.opera.enabled)" = "1" ] && opera_ok=1
	if custom_init_ok "$lan_ip" "$mixed_port"; then init_ok=1; fi
	if opera_proxy_running; then running_ok=1; fi
	if test_http_proxy; then proxy_ok=1; fi

	needs_fix=0
	[ "$proxy_ok" -eq 0 ] && needs_fix=1

	socks_url="socks5://${lan_ip}:${mixed_port}"
	json_ok_status "$needs_fix" "$lan_ip" "$socks_url" "$mixed_ok" "$opera_ok" "$init_ok" "$running_ok" "$proxy_ok" "$pkg_ver"
}

prepare_zeroblock_config() {
	mixed_was_enabled=1

	if [ "$(uci -q get "zeroblock.${ZB_SECTION}.enable_mixed_proxy")" != "1" ]; then
		mixed_was_enabled=0
		uci -q set "zeroblock.${ZB_SECTION}.enable_mixed_proxy=1"
		uci -q set "zeroblock.${ZB_SECTION}.mixed_port=${ZB_DEFAULT_MIXED_PORT}"
	fi

	if [ "$(uci -q get zeroblock.opera.enabled)" != "1" ]; then
		uci -q set zeroblock.opera.enabled=1
	fi

	uci commit zeroblock || json_err "Не удалось сохранить настройки Zeroblock"
	printf '%s' "$mixed_was_enabled"
}

write_opera_init() {
	lan_ip="$1"
	mixed_port="$2"

	cat > /etc/init.d/opera-proxy << EOF
#!/bin/sh /etc/rc.common
# routerich-panel: opera-proxy fixed

USE_PROCD=1
START=40
STOP=89
PROG=/usr/bin/opera-proxy

start_service() {
  procd_open_instance
  procd_set_param command "\$PROG" -verbosity 50 -country "EU" -proxy socks5://${lan_ip}:${mixed_port}
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_set_param respawn \${respawn_threshold:-3600} \${respawn_timeout:-5} \${respawn_retry:-5}
  procd_close_instance
}
EOF
	chmod +x /etc/init.d/opera-proxy
}

restart_zeroblock_and_opera() {
	/etc/init.d/zeroblock restart 2>/dev/null || json_err "Не удалось перезапустить Zeroblock"
	MIXED_PORT=$(get_mixed_port)
	if ! wait_for_port "$MIXED_PORT" 25; then
		json_err "Смешанный прокси ${ZB_SECTION} не слушает порт ${MIXED_PORT} после перезапуска Zeroblock"
	fi
	/etc/init.d/opera-proxy restart 2>/dev/null || json_err "Не удалось перезапустить opera-proxy"
}

apply_fix() {
	upgrade_opera_proxy_package
	PKG_VER=$(get_opera_proxy_version)

	LAN_IP=$(get_lan_ip)
	[ -n "$LAN_IP" ] || LAN_IP=$(uci -q get network.lan.ipaddr)
	[ -n "$LAN_IP" ] || json_err "Не удалось определить LAN-адрес роутера"

	if [ "$(uci -q get zeroblock.opera.enabled)" = "1" ]; then
		opera_was_enabled=1
	else
		opera_was_enabled=0
	fi

	mixed_was_enabled=$(prepare_zeroblock_config)
	MIXED_PORT=$(get_mixed_port)
	SOCKS_URL="socks5://${LAN_IP}:${MIXED_PORT}"

	restart_zeroblock_and_opera
	if wait_for_http_proxy; then
		json_ok_apply "$LAN_IP" "$SOCKS_URL" "$mixed_was_enabled" "$opera_was_enabled" "$PKG_VER" false \
			"Opera-Proxy обновлён и работает без кастомного исправления"
	fi

	write_opera_init "$LAN_IP" "$MIXED_PORT"
	restart_zeroblock_and_opera
	if ! wait_for_http_proxy; then
		json_err "opera-proxy не прошёл проверку через ${OPERA_HTTP_PROXY}. SOCKS: ${SOCKS_URL}"
	fi

	json_ok_apply "$LAN_IP" "$SOCKS_URL" "$mixed_was_enabled" "$opera_was_enabled" "$PKG_VER" true \
		"Opera-Proxy обновлён, применено кастомное исправление и проверено подключение"
}

echo "Content-Type: application/json"
echo ""

[ -x /usr/bin/opera-proxy ] || json_err "opera-proxy не установлен"

if podkop_installed; then
	case "$REQUEST_METHOD" in
		GET)
			collect_status_podkop
			;;
		POST)
			json_err "Установлен Podkop — исправление Opera-Proxy через Zeroblock недоступно. Настройте маршрутизацию в Podkop."
			;;
		*)
			json_err "Method not allowed"
			;;
	esac
fi

[ -f /etc/config/zeroblock ] || json_err "Zeroblock не установлен (требуется для исправления Opera-Proxy)"

case "$REQUEST_METHOD" in
	GET)
		collect_status
		;;
	POST)
		apply_fix
		;;
	*)
		json_err "Method not allowed"
		;;
esac